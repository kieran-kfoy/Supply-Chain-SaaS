# PostgreSQL connection via Supabase (session mode pooler)
# Get this from Supabase → Connect → Session pooler
DATABASE_URL="postgresql://postgres.YOUR_PROJECT_ID:YOUR_PASSWORD@aws-1-us-east-1.pooler.supabase.com:5432/postgres"

# Direct connection for Prisma migrations (same as DATABASE_URL for session pooler)
DIRECT_URL="postgresql://postgres.YOUR_PROJECT_ID:YOUR_PASSWORD@aws-1-us-east-1.pooler.supabase.com:5432/postgres"

# Supabase project URL and keys
# Get these from Supabase → Settings → API Keys
SUPABASE_URL="https://YOUR_PROJECT_ID.supabase.co"
SUPABASE_ANON_KEY="your_anon_key_here"
SUPABASE_SERVICE_ROLE_KEY="your_service_role_key_here"

# JWT secret for signing tokens (generate a random 32+ character string)
JWT_SECRET="your_jwt_secret_here"

# Gemini AI API key (optional)
GEMINI_API_KEY="your_gemini_api_key"

# App URL
APP_URL="http://localhost:3000"
